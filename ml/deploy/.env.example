# Environment variables for the OmicsAI FastAPI ML worker.
# Copy to `.env` for local dev:  cp ml/deploy/.env.example ml/.env
# In production, set these on the host (Fly secrets / Render env / Cloud Run).

# --- Required ---------------------------------------------------------------
# Supabase project this worker reads/writes against.
SUPABASE_URL=https://your-project-ref.supabase.co
# Service role key — NEVER expose to the browser. Used to update jobs/experiments/results.
SUPABASE_SERVICE_ROLE_KEY=replace-me

# Shared secret with the pipeline-orchestrator edge function.
# The edge function sends it as `X-Training-Webhook-Secret`; the worker rejects
# the request if it does not match.
ML_TRAINING_WEBHOOK_SECRET=replace-me-with-a-long-random-string

# --- Optional ---------------------------------------------------------------
# Durable run-state store for /status/{run_id}. Use "supabase" in production.
ML_RUN_STORE_BACKEND=supabase

# Disable synthetic-demo artifact fallback in production.
ML_ALLOW_SYNTHETIC_FALLBACK=false

# Cap on max_obs per spatial request.
ML_MAX_OBS_HARD_LIMIT=200000

# Port uvicorn binds to (Fly/Render/Railway override this automatically).
PORT=8787
