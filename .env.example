VITE_SUPABASE_PROJECT_ID="<your-supabase-project-ref>"
VITE_SUPABASE_URL="https://<your-project-ref>.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="<your-supabase-anon-key>"

# Optional: Python spatial ML API (uvicorn ml.api.main:app --port 8787)
# VITE_SPATIAL_API_URL="http://localhost:8787"

# Optional: absolute path on the ML worker for local dev (Spatial Studio / scripts)
# ML_SPATIAL_DEV_H5AD="/abs/path/to/repo/ml/data_pack/local/square_016um_dev.h5ad"

# ── Production Sprint 1: Spatial API hardening ──────────────────────────
# Durable run store backend ("inmemory" for dev, "supabase" for prod)
# ML_RUN_STORE_BACKEND="inmemory"

# Disable synthetic demo fallback in production (errors surface instead)
# ML_ALLOW_SYNTHETIC_FALLBACK="false"

# Hard upper limit for max_obs accepted by the API (default 200000)
# ML_MAX_OBS_HARD_LIMIT="200000"
